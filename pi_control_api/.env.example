# Pi 에서: cp .env.example .env 후 ./run_control.sh
# (메인 PC에서 브라우저 health 가 mock 이면 Pi 프로세스가 이 값을 안 읽은 것)

PI_MOCK_HW=0
MOTOR_DRIVER=yahboom
PTZ_DRIVER=yahboom
LIDAR_DRIVER=yahboom
IMU_DRIVER=yahboom

# 빠른 제어: Docker 안에 rclpy bridge worker를 상주시켜 바로 publish
YAHBOOM_BACKEND=bridge
ROS_DOMAIN_ID=20

# Docker CLI 테스트 모드: 검증된 shell script와 같은 --once 발행
YAHBOOM_DOCKER_STYLE=script_once

# 카메라 서보 pub 대기 시간. 2.0은 camera_pan.sh 원본, 0.3은 지연 감소 테스트값.
YAHBOOM_SERVO_SPIN_TIME=0.3

# Yahboom Docker 이미지 컨테이너 이름 (docker ps 로 확인 후 넣으면 안정적)
# YAHBOOM_CONTAINER=determined_taussig
